// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model IncomeSource {
  id        String   @id @default(uuid())
  name      String
  amount    Float
  frequency Frequency
  isPreTax  Boolean

  taxRate   Float?
  taxState  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SpendingCategory {
  id          String   @id @default(uuid())
  name        String

  limitType   LimitType
  limitValue  Float

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
  recurringTransactions RecurringTransaction[]
}

model SavingCategory {
  id         String   @id @default(uuid())
  name       String

  limitType  LimitType
  limitValue Float

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Transaction {
  id           String   @id @default(uuid())

  amount       Float
  date         DateTime
  description  String?

  categoryId   String
  category     SpendingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  recurringSeriesId String?
  recurringSeries   RecurringTransaction? @relation(fields: [recurringSeriesId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RecurringTransaction {
  id          String   @id @default(uuid())
  frequency   RecurrenceFrequency
  startDate   DateTime
  amount      Float
  description String?

  categoryId  String
  category    SpendingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Frequency {
  MONTHLY
  ANNUAL
}

enum LimitType {
  AMOUNT
  PERCENT
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}
