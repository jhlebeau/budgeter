// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model IncomeSource {
  id        String   @id @default(uuid())
  name      String
  amount    Float
  frequency Frequency
  isPreTax  Boolean
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startMonth String  @default("1970-01")
  endMonth   String?

  taxRate   Float?
  taxState  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SpendingCategory {
  id          String   @id @default(uuid())
  name        String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  limitType   LimitType
  limitValue  Float

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
  recurringTransactions RecurringTransaction[]
}

model SavingCategory {
  id         String   @id @default(uuid())
  name       String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  limitType  LimitType
  limitValue Float

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Transaction {
  id           String   @id @default(uuid())

  amount       Float
  date         DateTime
  description  String?
  userId       String
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId   String
  category     SpendingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  recurringSeriesId String?
  recurringSeries   RecurringTransaction? @relation(fields: [recurringSeriesId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RecurringTransaction {
  id          String   @id @default(uuid())
  frequency   RecurrenceFrequency
  startDate   DateTime
  endDate     DateTime?
  amount      Float
  description String?
  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId  String
  category    SpendingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  skippedDates RecurringTransactionSkipDate[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RecurringTransactionSkipDate {
  id                String   @id @default(uuid())
  recurringSeriesId String
  recurringSeries   RecurringTransaction @relation(fields: [recurringSeriesId], references: [id], onDelete: Cascade)
  date              DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([recurringSeriesId, date])
}

model User {
  id                      String    @id @default(uuid())
  username                String
  usernameKey             String    @unique
  passwordHash            String?
  recurringGeneratedDate  DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  incomeSources           IncomeSource[]
  spendingCategories      SpendingCategory[]
  savingCategories        SavingCategory[]
  transactions            Transaction[]
  recurringTransactions   RecurringTransaction[]
}

enum Frequency {
  MONTHLY
  ANNUAL
}

enum LimitType {
  AMOUNT
  PERCENT
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}
